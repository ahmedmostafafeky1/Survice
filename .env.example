APP_NAME=Survice
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file

# ─── Lusha ────────────────────────────────────────────────────────────────────
# Obtain your API key from https://dashboard.lusha.com/settings/api
LUSHA_API_KEY=your_lusha_api_key_here
LUSHA_BASE_URL=https://api.lusha.com
LUSHA_TIMEOUT=30
LUSHA_DEFAULT_LIMIT=25
